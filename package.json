{
  "name": "banco-horas-2026",
  "version": "1.0.0",
  "description": "Monitoramento de Banco de Horas 2026 — Live Roupas Esportivas",
  "main": "main.js",
  "author": "Manoel Cláudio da Silva Tavares Filho",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.live.bancohoras",
    "productName": "Banco de Horas 2026",
    "directories": { "output": "dist" },
    "files": ["main.js", "src/**/*"],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "src/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Banco de Horas 2026"
    },
    "mac": { "target": "dmg" },
    "linux": { "target": ["AppImage", "deb"] }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
